# 1. Configuración básica de reescritura
RewriteEngine On
RewriteBase /

# 2. Si el archivo o carpeta solicitado realmente existe, que el servidor lo sirva
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. Evitar que el servidor intente redirigir archivos estáticos (JS, CSS, Imágenes)
RewriteRule \.(js|css|png|jpg|ico|svg|json|woff2?|ttf|eot)$ - [L]

# 4. Todo lo demás (las rutas de Angular) se envía a index.html
RewriteRule ^ index.html [L]